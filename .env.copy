# ── WALLET ──────────────────────────────────────────────
PRIVATE_KEY=your_wallet_private_key_here

# ── RPC ENDPOINTS ────────────────────────────────────────
RPC_ENDPOINT=https://polygon-rpc.com
RPC_WEBSOCKET_ENDPOINT=wss://polygon-bor-rpc.publicnode.com

# ── BOT SETTINGS ─────────────────────────────────────────
LOG_LEVEL=info
# Max MATIC to spend per snipe
BUY_AMOUNT=0.5
# Slippage tolerance in % (e.g. 10 = 10%)
SLIPPAGE=10
# Delay in ms before buying after pair detected
BUY_DELAY=500
# Max retries for failed transactions
MAX_RETRIES=3

# ── SELL SETTINGS ────────────────────────────────────────
AUTO_SELL=true
# Delay in ms before auto-selling
AUTO_SELL_DELAY=60000
# Take profit % (e.g. 50 = sell at 50% gain)
TAKE_PROFIT=50
# Stop loss % (e.g. 20 = sell if down 20%)
STOP_LOSS=20

# ── FILTERS ──────────────────────────────────────────────
# Only snipe if paired with WMATIC or USDC
QUOTE_TOKEN=WMATIC
# Min liquidity in USD before sniping
MIN_LIQUIDITY=1000
# Check if liquidity is locked before buying
CHECK_LIQUIDITY_LOCK=true
